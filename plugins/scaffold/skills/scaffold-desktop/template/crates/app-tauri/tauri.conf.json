{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "App",
  "version": "0.1.0",
  "identifier": "com.app.dev",
  "build": {
    "beforeDevCommand": "cd app && trunk serve --port 1420",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd app && trunk build",
    "frontendDist": "../app/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "App",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.png"]
  }
}
