# Default: run all checks
default: check test

# Format code
fmt:
    cargo fmt --all

# Check formatting (CI)
fmt-check:
    cargo fmt --all -- --check

# Run clippy (excludes frontend — use wasm target for that)
check:
    cargo clippy --workspace --all-targets --exclude app-frontend -- -D warnings

# Run backend tests
test:
    cargo test --workspace --exclude app-frontend

# Run frontend wasm tests (requires wasm-pack: cargo install wasm-pack)
test-wasm:
    wasm-pack test --headless --chrome crates/app-frontend

# Run tests with all feature combinations
test-features:
    cargo test --workspace
    cargo test --workspace --no-default-features
    cargo test --workspace --all-features

# Full CI pipeline locally
ci: fmt-check check test-features

# Run everything including frontend
ci-all: ci test-wasm build-frontend

# Build in release mode
build:
    cargo build --workspace --release

# Build frontend WASM
build-frontend:
    cd frontend && npm install && npm run build

# Clean build artifacts
clean:
    cargo clean

# Watch and run tests on change (requires cargo-watch)
watch:
    cargo watch -x 'test --workspace'
