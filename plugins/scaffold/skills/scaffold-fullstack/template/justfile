# Default: run all checks
default: check test

# Format code
fmt:
    cargo fmt --all

# Check formatting (CI)
fmt-check:
    cargo fmt --all -- --check

# Run clippy (excludes frontend WASM targets)
check:
    cargo clippy --workspace --all-targets --exclude app-frontend -- -D warnings

# Run all tests (backend + frontend state tests)
test:
    cargo test --workspace --exclude app-frontend
    cargo test -p app-frontend --lib

# Run tests with all feature combinations
test-features:
    cargo test --workspace --exclude app-frontend
    cargo test --workspace --exclude app-frontend --no-default-features
    cargo test --workspace --exclude app-frontend --all-features
    cargo test -p app-frontend --lib

# Full CI pipeline locally
ci: fmt-check check test-features

# CI including frontend WASM build
ci-all: ci build-frontend

# Build in release mode
build:
    cargo build --workspace --release

# Build frontend WASM
build-frontend:
    cd frontend && npm install && npm run build

# Clean build artifacts
clean:
    cargo clean

# Watch and run tests on change (requires cargo-watch)
watch:
    cargo watch -x 'test --workspace --exclude app-frontend'
