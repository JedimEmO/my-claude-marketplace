FROM rust:1.85-slim AS rust-builder

RUN rustup target add wasm32-unknown-unknown
RUN apt-get update && apt-get install -y curl pkg-config libssl-dev && rm -rf /var/lib/apt/lists/*

# Install Node.js
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y nodejs

WORKDIR /app

# Cache npm dependencies (before copying Rust source)
COPY frontend/package.json frontend/package.json
RUN cd frontend && npm install

# Copy workspace manifests for Rust dep caching
COPY Cargo.toml Cargo.lock ./
COPY crates/app-core/Cargo.toml crates/app-core/Cargo.toml
COPY crates/app-api/Cargo.toml crates/app-api/Cargo.toml
COPY crates/app-adapters/Cargo.toml crates/app-adapters/Cargo.toml
COPY crates/app-service/Cargo.toml crates/app-service/Cargo.toml
COPY crates/app-testutils/Cargo.toml crates/app-testutils/Cargo.toml
COPY crates/app-frontend/Cargo.toml crates/app-frontend/Cargo.toml

# Create stub src files
RUN mkdir -p crates/app-core/src && echo "" > crates/app-core/src/lib.rs && \
    mkdir -p crates/app-api/src && echo "" > crates/app-api/src/lib.rs && \
    mkdir -p crates/app-adapters/src && echo "" > crates/app-adapters/src/lib.rs && \
    mkdir -p crates/app-service/src && echo "fn main() {}" > crates/app-service/src/main.rs && \
    mkdir -p crates/app-testutils/src && echo "" > crates/app-testutils/src/lib.rs && \
    mkdir -p crates/app-frontend/src && echo "" > crates/app-frontend/src/lib.rs

# Pre-fetch Rust dependencies
RUN cargo build --target wasm32-unknown-unknown -p app-frontend 2>/dev/null || true

# Copy actual source
COPY crates/ crates/
RUN find crates -name "*.rs" -exec touch {} +

# Copy frontend build config
COPY frontend/rollup.config.js frontend/rollup.config.js
COPY frontend/index.html frontend/index.html

# Build WASM
RUN cargo build --release --target wasm32-unknown-unknown -p app-frontend

# Build JS bundle
WORKDIR /app/frontend
RUN RELEASE=true npm run build

# Serve with nginx
FROM nginx:alpine

COPY --from=rust-builder /app/frontend/dist/ /usr/share/nginx/html/
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 8080
